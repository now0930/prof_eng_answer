# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# LLM provider selection
# auto   : Gemini primary, Clova fallback
# gemini : Gemini only
# clova  : Clova only
LLM_PROVIDER=auto
LLM_PRIMARY=gemini
LLM_FALLBACK=clova

# Naver CLOVA Studio
# 새 방식은 CLOVA_API_KEY만 사용한다.
# CLOVA_APIGW_API_KEY는 Legacy 방식이 필요할 때만 사용한다.
CLOVA_API_KEY=
CLOVA_REQUEST_ID=prof-eng-answer-local
CLOVA_MODEL=HCX-003
CLOVA_HOST=https://clovastudio.stream.ntruss.com
CLOVA_ENDPOINT=/v1/chat-completions/HCX-003
